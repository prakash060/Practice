# PK Food Factory Backend — environment template
# Copy this file to .env and replace placeholder values. Never commit .env.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/foodfactory

# --- Razorpay (use test keys for local dev: rzp_test_...) ---
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Auth / JWT ---
# Generate a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret

# Admin menu access (must match a registered user email)
ADMIN_EMAIL=admin@example.com

# --- OTP: Email (Gmail SMTP — free ~500/day) ---
# 1. Enable 2FA on Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password as EMAIL_PASS (not your Gmail login password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="SVI Foods <your_gmail@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- OTP: SMS (India — MSG91) ---
# Sign up: https://msg91.com
# Create Flow/OTP template with one variable for the 6-digit code (e.g. ##var##)
# Production: complete DLT registration (entity + sender ID + template) or carriers may block SMS
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_approved_flow_template_id

# --- OTP: SMS (optional — Twilio trial, verified numbers only) ---
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1234567890

# --- OTP: Development fallback ---
# When true, failed email/SMS still log codes to console and API may return devOtp (non-production)
OTP_DEV_LOG=true

# Production: NODE_ENV=production and OTP_DEV_LOG=false (no dev codes in API/UI)
